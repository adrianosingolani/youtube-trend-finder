{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build-init": "tailwindcss init -p",
    "test": "vitest run --passWithNoTests",
    "openapi:types": "wait-on -t 120000 http-get://127.0.0.1:3000/openapi.json && openapi-typescript http://localhost:3000/openapi.json -o src/api/schema.d.ts"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
