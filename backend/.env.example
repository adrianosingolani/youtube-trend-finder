# PostgreSQL (required for Prisma + ingest)
DATABASE_URL=postgresql://user:password@localhost:5432/youtube_trends

# Internal ingest API (header X-API-Key)
API_KEY=change-me

# LLM providers — set keys for whichever models you use in LLM_MODEL_CHAIN
# Gemini (first in default chain)
GOOGLE_API_KEY=
# Optional alias read by the same code path
GEMINI_API_KEY=

# Groq (OpenAI-compatible base URL inside the app)
GROQ_API_KEY=

# OpenAI (only if your chain includes provider "openai")
OPENAI_API_KEY=

# Optional: override the full model chain as JSON (see src/llm/model-chain.ts for defaults)
# LLM_MODEL_CHAIN=[{"provider":"gemini","model":"gemini-3.1-flash-lite-preview"},{"provider":"groq","model":"llama-3.1-8b-instant"}]

# Light workload thresholds (start cheaper models when under both limits)
LLM_LIGHT_MAX_VIDEOS=15
LLM_LIGHT_MAX_CHARS=24000

# Model id substring or exact match used as the light-workload entry (default: llama-3.1-8b-instant)
LLM_LIGHT_ENTRY_MODEL=llama-3.1-8b-instant

# Per-attempt HTTP timeout for LLM calls (ms)
LLM_TIMEOUT_MS=25000

LOG_LEVEL=info
NODE_ENV=development
